rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /participants/{participantId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name', 'createdAtMs', 'companionCount']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 80 &&
        request.resource.data.createdAtMs is int &&
        (
          !request.resource.data.keys().hasAny(['companionCount']) ||
          (
            request.resource.data.companionCount is int &&
            request.resource.data.companionCount >= 0 &&
            request.resource.data.companionCount <= 20
          )
        );
      allow update: if false;
      allow delete: if true;
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name', 'url', 'createdAtMs', 'storagePath']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.url is string &&
        request.resource.data.storagePath is string &&
        request.resource.data.createdAtMs is int;
      allow update, delete: if false;
    }
  }
}
